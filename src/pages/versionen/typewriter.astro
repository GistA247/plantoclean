---
import PreviewLayout from "../../layouts/PreviewLayout.astro";
import USPGrid from "../../components/sections/USPGrid.astro";
import ServiceAreaMap from "../../components/sections/ServiceAreaMap.astro";
import ServicesPreview from "../../components/sections/ServicesPreview.astro";
import Testimonials from "../../components/sections/Testimonials.astro";
import SeasonalTip from "../../components/sections/SeasonalTip.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import { heroImage } from "../../data/images";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<PreviewLayout title="Typewriter Effekt">
  <!-- Hero with Typewriter Effect -->
  <section class="relative min-h-[calc(100vh-5rem)] flex items-center justify-center overflow-hidden">
    <img
      src={heroImage.url}
      alt={heroImage.alt.de}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-primary/60 mix-blend-multiply"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center text-white">
      <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
        Plantoclean –<br />
        <span class="italic font-light">alles&nbsp;<span id="tw-hero"></span></span>
      </h1>

      <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-10 leading-relaxed">
        Ihr Partner fuer professionelle Gruenpflege in NRW. Wir bringen Struktur und Aesthetik in Ihren Aussenbereich.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}/kontakt/`}
          class="inline-flex items-center gap-2 bg-white text-primary font-semibold px-8 py-4 rounded-full hover:bg-white/90 transition-colors"
        >
          Jetzt Anfrage senden
          <span class="material-icons text-xl">arrow_forward</span>
        </a>
        <a
          href={`${base}/leistungen/`}
          class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/30 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition-colors"
        >
          Unsere Leistungen
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <span class="material-icons text-white/70 text-4xl">expand_more</span>
    </div>
  </section>

  <!-- Rest of homepage -->
  <USPGrid />
  <ServiceAreaMap />
  <ServicesPreview />
  <Testimonials />
  <SeasonalTip />
  <CTABanner />
</PreviewLayout>

<style>
  @keyframes tw-blink {
    50% { border-color: transparent; }
  }
</style>

<script>
  const phrases = [
    "sauber?!",
    "grün?!",
    "gepflegt?!",
    "in Form?!",
    "natürlich?!",
    "im Griff?!",
    "geschnitten?!",
    "blüht?!",
    "nachhaltig?!",
    "wie neu?!",
    "professionell?!",
    "ordentlich?!",
  ];

  const target = document.getElementById("tw-hero");

  if (target) {
    let phraseIdx = 0;
    let charIdx = 0;
    let isDeleting = false;

    // Cursor style
    target.style.borderRight = "3px solid white";
    target.style.paddingRight = "4px";
    target.style.animation = "tw-blink 0.7s step-end infinite";

    function tick() {
      const phrase = phrases[phraseIdx];

      if (!isDeleting) {
        charIdx++;
        target!.textContent = phrase.slice(0, charIdx);

        if (charIdx === phrase.length) {
          setTimeout(() => { isDeleting = true; tick(); }, 2200);
          return;
        }
        setTimeout(tick, 100);
      } else {
        charIdx--;
        target!.textContent = phrase.slice(0, charIdx);

        if (charIdx === 0) {
          isDeleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(tick, 500);
          return;
        }
        setTimeout(tick, 50);
      }
    }

    setTimeout(tick, 600);
  }
</script>
